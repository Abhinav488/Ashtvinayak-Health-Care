<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="floor" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#D4A574"/>
      <stop offset="100%" style="stop-color:#B8956A"/>
    </linearGradient>
    <linearGradient id="wallLight" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#fafafa"/>
      <stop offset="100%" style="stop-color:#f0f0f0"/>
    </linearGradient>
  </defs>
  <!-- Floor -->
  <rect y="500" width="1200" height="300" fill="url(#floor)"/>
  <line x1="0" y1="500" x2="1200" y2="500" stroke="#A0855A" stroke-width="3"/>
  <!-- Wall -->
  <rect width="1200" height="500" fill="url(#wallLight)"/>
  <!-- Reception Desk -->
  <rect x="350" y="280" width="500" height="220" fill="#0A6EBD" rx="10"/>
  <rect x="370" y="300" width="460" height="180" fill="#ffffff" rx="5"/>
  <!-- Desk Logo -->
  <rect x="530" y="310" width="140" height="40" fill="#0A6EBD" rx="5"/>
  <text x="600" y="338" text-anchor="middle" font-family="Arial" font-size="18" fill="#ffffff" font-weight="bold">RECEPTION</text>
  <!-- Computer -->
  <rect x="450" y="360" width="120" height="80" fill="#333" rx="5"/>
  <rect x="455" y="365" width="110" height="60" fill="#1a1a2e"/>
  <rect x="510" y="440" width="60" height="20" fill="#666" rx="2"/>
  <!-- Keyboard -->
  <rect x="480" y="450" width="80" height="20" fill="#444" rx="3"/>
  <!-- Waiting Chairs -->
  <rect x="150" y="550" width="120" height="60" fill="#2E8B57" rx="8"/>
  <rect x="150" y="610" width="120" height="15" fill="#1E7B47"/>
  <rect x="250" y="550" width="120" height="60" fill="#2E8B57" rx="8"/>
  <rect x="250" y="610" width="120" height="15" fill="#1E7B47"/>
  <rect x="930" y="550" width="120" height="60" fill="#2E8B57" rx="8"/>
  <rect x="930" y="610" width="120" height="15" fill="#1E7B47"/>
  <rect x="830" y="550" width="120" height="60" fill="#2E8B57" rx="8"/>
  <rect x="830" y="610" width="120" height="15" fill="#1E7B47"/>
  <!-- Plant -->
  <rect x="80" y="400" width="40" height="100" fill="#8B4513"/>
  <ellipse cx="100" cy="390" rx="35" ry="40" fill="#228B22"/>
  <ellipse cx="85" cy="370" rx="25" ry="30" fill="#32CD32"/>
  <ellipse cx="115" cy="375" rx="25" ry="28" fill="#2ECC71"/>
  <!-- Wall Clock -->
  <circle cx="1050" cy="200" r="60" fill="#ffffff" stroke="#0A6EBD" stroke-width="4"/>
  <line x1="1050" y1="200" x2="1050" y2="160" stroke="#333" stroke-width="3"/>
  <line x1="1050" y1="200" x2="1080" y2="200" stroke="#333" stroke-width="3"/>
  <circle cx="1050" cy="200" r="5" fill="#0A6EBD"/>
  <!-- TV/Monitor -->
  <rect x="750" y="150" width="200" height="120" fill="#1a1a2e" rx="5"/>
  <rect x="755" y="155" width="190" height="100" fill="#2a2a4e"/>
  <rect x="840" y="270" width="40" height="15" fill="#333"/>
  <!-- Lights -->
  <rect x="300" y="0" width="100" height="30" fill="#ffffff"/>
  <rect x="800" y="0" width="100" height="30" fill="#ffffff"/>
  <!-- Magazine Rack -->
  <rect x="1050" y="420" width="80" height="80" fill="#666" rx="3"/>
  <rect x="1055" y="430" width="70" height="15" fill="#c00" rx="2"/>
  <rect x="1055" y="448" width="70" height="15" fill="#0066cc" rx="2"/>
  <rect x="1055" y="466" width="70" height="15" fill="#2E8B57" rx="2"/>
  <!-- Welcome Sign -->
  <rect x="450" y="80" width="300" height="50" fill="#0A6EBD" rx="25"/>
  <text x="600" y="113" text-anchor="middle" font-family="Arial" font-size="24" fill="#ffffff" font-weight="bold">Welcome</text>
</svg>