<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="bg3" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f5f5f5"/>
      <stop offset="100%" style="stop-color:#e0e0e0"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="800" fill="url(#bg3)"/>
  <!-- Table -->
  <rect x="50" y="550" width="1100" height="250" fill="#f8f8f8"/>
  <rect x="50" y="550" width="1100" height="20" fill="#ddd"/>
  <!-- BP Monitor -->
  <rect x="150" y="420" width="120" height="80" fill="#ffffff" stroke="#0A6EBD" stroke-width="3" rx="10"/>
  <rect x="170" y="440" width="80" height="50" fill="#1a1a2e" rx="5"/>
  <text x="210" y="470" text-anchor="middle" font-family="monospace" font-size="16" fill="#00ff00">120/80</text>
  <rect x="200" y="500" width="20" height="50" fill="#333"/>
  <!-- Stethoscope -->
  <path d="M350,380 Q330,350 360,330 Q390,310 380,380" fill="none" stroke="#333" stroke-width="5"/>
  <circle cx="380" cy="380" r="20" fill="#c0c0c0" stroke="#666" stroke-width="3"/>
  <circle cx="380" cy="380" r="10" fill="#808080"/>
  <!-- Glucometer -->
  <rect x="480" y="440" width="80" height="60" fill="#2ECC71" rx="8"/>
  <rect x="495" y="450" width="50" height="35" fill="#1a1a2e" rx="3"/>
  <text x="520" y="470" text-anchor="middle" font-family="monospace" font-size="10" fill="#00ff00">95</text>
  <rect x="510" y="495" width="20" height="5" fill="#333"/>
  <!-- Thermometer -->
  <rect x="620" y="450" width="15" height="60" fill="#ffffff" rx="3"/>
  <circle cx="627" cy="500" r="8" fill="#ff6b6b"/>
  <rect x="622" y="455" width="10" height="40" fill="#87CEEB" rx="2"/>
  <!-- Pulse Oximeter -->
  <rect x="700" y="450" width="50" height="50" fill="#0A6EBD" rx="8"/>
  <ellipse cx="725" cy="475" rx="15" ry="20" fill="#1a1a2e"/>
  <text x="725" y="480" text-anchor="middle" font-family="monospace" font-size="12" fill="#00ff00">98</text>
  <!-- Nebulizer -->
  <rect x="820" y="350" width="150" height="120" fill="#ffffff" stroke="#ccc" stroke-width="2" rx="10"/>
  <rect x="835" y="365" width="120" height="40" fill="#87CEEB" rx="5"/>
  <rect x="850" y="420" width="30" height="50" fill="#333"/>
  <path d="M860,380 L860,420 L840,420" fill="none" stroke="#666" stroke-width="3"/>
  <circle cx="835" cy="375" r="10" fill="#2ECC71"/>
  <text x="890" y="440" text-anchor="middle" font-family="Arial" font-size="10" fill="#333">Nebulizer</text>
  <!-- First Aid Kit -->
  <rect x="150" y="200" width="150" height="100" fill="#c00" rx="8"/>
  <rect x="175" y="210" width="100" height="20" fill="#ffffff" rx="3"/>
  <text x="225" y="225" text-anchor="middle" font-family="Arial" font-size="12" fill="#c00" font-weight="bold">FIRST AID</text>
  <circle cx="225" cy="265" r="15" fill="#ffffff"/>
  <rect x="218" y="255" width="14" height="28" fill="#c00"/>
  <rect x="208" y="265" width="34" height="14" fill="#c00"/>
  <!-- Medicine Cabinet -->
  <rect x="400" y="180" width="180" height="120" fill="#ffffff" stroke="#ccc" stroke-width="2" rx="5"/>
  <rect x="410" y="190" width="75" height="100" fill="#e8f4f8" rx="3"/>
  <rect x="495" y="190" width="75" height="100" fill="#e8f4f8" rx="3"/>
  <line x1="490" y1="180" x2="490" y2="300" stroke="#ccc" stroke-width="2"/>
  <circle cx="440" cy="240" r="8" fill="#0066cc"/>
  <circle cx="470" cy="260" r="8" fill="#c00"/>
  <circle cx="440" cy="270" r="8" fill="#2E8B57"/>
  <circle cx="520" cy="240" r="8" fill="#FFD700"/>
  <circle cx="550" cy="260" r="8" fill="#9400D3"/>
  <circle cx="520" cy="270" r="8" fill="#FF6600"/>
  <!-- Medical Files/Tablets -->
  <rect x="650" y="220" width="100" height="130" fill="#f5f5f5" stroke="#ddd" stroke-width="2" rx="3"/>
  <rect x="660" y="230" width="80" height="15" fill="#0066cc" rx="2"/>
  <rect x="660" y="250" width="80" height="15" fill="#c00" rx="2"/>
  <rect x="660" y="270" width="80" height="15" fill="#2E8B57" rx="2"/>
  <rect x="660" y="290" width="80" height="15" fill="#FFD700" rx="2"/>
  <rect x="660" y="310" width="80" height="20" fill="#9400D3" rx="2"/>
  <!-- Wheelchair -->
  <rect x="850" y="300" width="120" height="10" fill="#333" rx="3"/>
  <circle cx="880" cy="360" r="35" fill="#333" stroke="#666" stroke-width="3"/>
  <circle cx="880" cy="360" r="15" fill="#666"/>
  <circle cx="950" cy="360" r="35" fill="#333" stroke="#666" stroke-width="3"/>
  <circle cx="950" cy="360" r="15" fill="#666"/>
  <rect x="890" y="250" width="15" height="80" fill="#333"/>
  <rect x="900" y="230" width="40" height="30" fill="#333" rx="3"/>
  <text x="920" y="440" text-anchor="middle" font-family="Arial" font-size="12" fill="#666">Wheelchair</text>
  <!-- Oxygen Cylinder -->
  <rect x="1050" y="280" width="60" height="200" fill="#f0f0f0" stroke="#999" stroke-width="2" rx="30"/>
  <rect x="1060" y="260" width="40" height="25" fill="#888" rx="5"/>
  <rect x="1070" y="250" width="20" height="15" fill="#666" rx="3"/>
  <circle cx="1080" cy="300" r="15" fill="#0A6EBD"/>
  <text x="1080" y="380" text-anchor="middle" font-family="Arial" font-size="10" fill="#666">O2</text>
  <!-- Scale -->
  <rect x="50" y="400" width="80" height="10" fill="#ccc" rx="3"/>
  <rect x="60" y="410" width="60" height="80" fill="#f0f0f0"/>
  <rect x="70" y="420" width="40" height="50" fill="#87CEEB" rx="3"/>
  <!-- Wall Shelf with More Equipment -->
  <rect x="50" y="80" width="300" height="20" fill="#8B4513"/>
  <rect x="60" y="100" width="60" height="80" fill="#2ECC71" rx="5"/>
  <rect x="130" y="100" width="60" height="80" fill="#0066cc" rx="5"/>
  <rect x="200" y="100" width="60" height="80" fill="#c00" rx="5"/>
  <rect x="270" y="100" width="60" height="80" fill="#9400D3" rx="5"/>
</svg>