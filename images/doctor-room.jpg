<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="floor2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#E8DFD0"/>
      <stop offset="100%" style="stop-color:#D4C4B0"/>
    </linearGradient>
    <linearGradient id="wall2" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#f8f8f8"/>
      <stop offset="100%" style="stop-color:#f0f0f0"/>
    </linearGradient>
  </defs>
  <!-- Floor -->
  <rect y="550" width="1200" height="250" fill="url(#floor2)"/>
  <!-- Wall -->
  <rect width="1200" height="550" fill="url(#wall2)"/>
  <!-- Wooden Baseboard -->
  <rect y="530" width="1200" height="20" fill="#A0522D"/>
  <!-- Doctor's Desk -->
  <rect x="350" y="350" width="500" height="180" fill="#8B4513" rx="8"/>
  <rect x="360" y="360" width="480" height="80" fill="#A0522D"/>
  <rect x="370" y="450" width="460" height="70" fill="#8B4513"/>
  <!-- Desk Lamp -->
  <rect x="600" y="330" width="40" height="20" fill="#333"/>
  <path d="M600,350 L620,380 L640,350 Z" fill="#FFD700"/>
  <ellipse cx="620" cy="345" rx="30" ry="20" fill="#FFE4B5" opacity="0.8"/>
  <!-- Computer Monitor -->
  <rect x="420" y="250" width="150" height="100" fill="#1a1a2e" rx="5"/>
  <rect x="425" y="255" width="140" height="85" fill="#2a2a4e"/>
  <rect x="490" y="350" width="40" height="30" fill="#333"/>
  <!-- Medical Files -->
  <rect x="700" y="340" width="80" height="100" fill="#0066cc" rx="3"/>
  <rect x="705" y="345" width="70" height="20" fill="#ffffff"/>
  <text x="740" y="360" text-anchor="middle" font-family="Arial" font-size="8" fill="#333">Medical</text>
  <rect x="700" y="395" width="80" height="40" fill="#c00" rx="3"/>
  <text x="740" y="415" text-anchor="middle" font-family="Arial" font-size="8" fill="#ffffff">Patient</text>
  <!-- Doctor Chair -->
  <ellipse cx="600" cy="540" rx="80" ry="20" fill="#333"/>
  <rect x="580" y="530" width="40" height="60" fill="#222"/>
  <ellipse cx="600" cy="530" rx="40" ry="10" fill="#0A6EBD"/>
  <!-- Examination Table -->
  <rect x="100" y="380" width="180" height="60" fill="#ffffff" stroke="#ccc" rx="5"/>
  <rect x="100" y="440" width="180" height="100" fill="#e0e0e0" rx="5"/>
  <rect x="120" y="400" width="140" height="20" fill="#0A6EBD" rx="3"/>
  <!-- Stethoscope -->
  <path d="M150,350 Q130,320 160,300 Q190,280 180,350" fill="none" stroke="#333" stroke-width="4"/>
  <circle cx="180" cy="350" r="15" fill="#c0c0c0" stroke="#666" stroke-width="2"/>
  <!-- Wall Medical Charts -->
  <rect x="850" y="100" width="150" height="200" fill="#ffffff" stroke="#ddd" stroke-width="2"/>
  <line x1="870" y1="120" x2="980" y2="120" stroke="#0066cc" stroke-width="2"/>
  <line x1="870" y1="140" x2="980" y2="140" stroke="#c00" stroke-width="2"/>
  <line x1="870" y1="160" x2="980" y2="160" stroke="#2E8B57" stroke-width="2"/>
  <line x1="870" y1="180" x2="980" y2="180" stroke="#FFD700" stroke-width="2"/>
  <line x1="870" y1="200" x2="980" y2="200" stroke="#333" stroke-width="2"/>
  <line x1="870" y1="220" x2="980" y2="220" stroke="#333" stroke-width="2"/>
  <line x1="870" y1="240" x2="980" y2="240" stroke="#333" stroke-width="2"/>
  <line x1="870" y1="260" x2="980" y2="260" stroke="#333" stroke-width="2"/>
  <!-- Medical Certificate Frame -->
  <rect x="50" y="100" width="120" height="160" fill="#ffffff" stroke="#DAA520" stroke-width="4"/>
  <rect x="55" y="105" width="110" height="150" fill="#f5f5dc"/>
  <text x="110" y="140" text-anchor="middle" font-family="Georgia" font-size="12" fill="#DAA520" font-weight="bold">MD</text>
  <text x="110" y="160" text-anchor="middle" font-family="Arial" font-size="8" fill="#333">Best Doctor</text>
  <!-- Sink -->
  <rect x="1050" y="380" width="80" height="100" fill="#ffffff" stroke="#ccc"/>
  <ellipse cx="1090" cy="400" rx="30" ry="15" fill="#87CEEB"/>
  <rect x="1070" y="340" width="40" height="50" fill="#ccc"/>
  <!-- Ceiling Light -->
  <rect x="500" y="0" width="200" height="30" fill="#ffffff"/>
  <rect x="520" y="5" width="160" height="20" fill="#FFFACD"/>
  <!-- Curtains -->
  <rect x="50" y="50" width="80" height="500" fill="#E6E6FA" opacity="0.7"/>
  <rect x="1070" y="50" width="80" height="500" fill="#E6E6FA" opacity="0.7"/>
  <!-- Door -->
  <rect x="300" y="0" width="10" height="550" fill="#8B4513"/>
</svg>